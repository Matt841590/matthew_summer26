{
    "name": "Kaia.ai ROS2 Dev Environment",
    "image": "kaiaai/kaiaai:iron",

    // Translates your -p, -e, and --name options into VS Code equivalents
    "runArgs": [
        "--name=makerspet",
        "-p", "192.168.12.153:8888:8888/udp",
        "-p", "192.168.12.153:4430:4430/tcp",
        "-e", "DISPLAY=host.docker.internal:0.0",
        "-e", "LIBGL_ALWAYS_INDIRECT=0",
        "--net=host"
    ],

    // Mounts your current GitHub repository workspace directly into the ROS2 workspace src folder inside the container
    "workspaceMount": "source=${localWorkspaceFolder},target=/ros_ws/src/${localWorkspaceFolderBasename},type=bind",
    "workspaceFolder": "/",

    // Optional: Sources your ROS2 environment automatically when a new terminal opens
    "postCreateCommand": "bash /ros_ws/src/matthew_summer26/.devcontainer/setup.sh"
}

